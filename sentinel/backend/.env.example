# Copy this file to .env and fill in your values.
# CaseMind Sentinel routes LLM calls through a Portkey AI Gateway using
# Anthropic-compatible API configuration. The Anthropic SDK is pointed at the
# Portkey base URL; the gateway handles routing to the underlying model provider.

LLM_PROVIDER=portkey

PORTKEY_API_KEY=<PORTKEY_API_KEY>
PORTKEY_BASE_URL=<PORTKEY_BASE_URL>
PORTKEY_MODEL=<PORTKEY_MODEL>
PORTKEY_PROVIDER=<PORTKEY_PROVIDER>
